    "## 🗺️ PARTE 4: Definir Ubicaciones Relevantes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define las ciudades/puertos relevantes para tu proyecto de logística\n",
    "# Puedes obtener esto desde tus datos de shipping si tienes columnas de origen/destino\n",
    "\n",
    "# Ejemplo: Principales puertos marítimos de España\n",
    "LOCATIONS = [\n",
    "    {'name': 'Barcelona', 'country': 'ES', 'type': 'puerto'},\n",
    "    {'name': 'Valencia', 'country': 'ES', 'type': 'puerto'},\n",
    "    {'name': 'Algeciras', 'country': 'ES', 'type': 'puerto'},\n",
    "    {'name': 'Bilbao', 'country': 'ES', 'type': 'puerto'},\n",
    "    {'name': 'Madrid', 'country': 'ES', 'type': 'ciudad'},\n",
    "]\n",
    "\n",
    "# O carga desde tu CSV de shipping si tienes columnas de ubicación\n",
    "# Ejemplo:\n",
    "# try:\n",
    "#     df_shipping = pd.read_csv(PROJECT_ROOT / 'data/processed/shipping_clean.csv')\n",
    "#     if 'origin_city' in df_shipping.columns:\n",
    "#         cities = df_shipping['origin_city'].unique().tolist()\n",
    "#         LOCATIONS = [{'name': city, 'country': 'ES', 'type': 'ciudad'} for city in cities]\n",
    "# except:\n",
    "#     pass\n",
    "\n",
    "print(\"📍 UBICACIONES CONFIGURADAS:\\n\")\n",
    "for loc in LOCATIONS:\n",
    "    print(f\"   • {loc['name']} ({loc['country']}) - {loc['type']}\")\n",
    "\n",
    "print(f\"\\n   Total: {len(LOCATIONS)} ubicaciones\")"
   ]
