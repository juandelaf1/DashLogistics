    "if not df_weather_current.empty:\n",
    "    print(\"📈 ESTADÍSTICAS DESCRIPTIVAS:\\n\")\n",
    "    print(df_weather_current[['temperature_celsius', 'humidity_percent', 'wind_speed_ms']].describe())\n",
    "    \n",
    "    # Visualizaciones\n",
    "    fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "    \n",
    "    # Temperatura por ubicación\n",
    "    df_weather_current.plot(x='location', y='temperature_celsius', kind='bar', ax=axes[0, 0], color='orange')\n",
    "    axes[0, 0].set_title('Temperatura por Ubicación', fontsize=14, fontweight='bold')\n",
    "    axes[0, 0].set_ylabel('°C')\n",
    "    axes[0, 0].tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # Humedad por ubicación\n",
    "    df_weather_current.plot(x='location', y='humidity_percent', kind='bar', ax=axes[0, 1], color='blue')\n",
    "    axes[0, 1].set_title('Humedad por Ubicación', fontsize=14, fontweight='bold')\n",
    "    axes[0, 1].set_ylabel('%')\n",
    "    axes[0, 1].tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # Velocidad del viento\n",
    "    df_weather_current.plot(x='location', y='wind_speed_ms', kind='bar', ax=axes[1, 0], color='green')\n",
    "    axes[1, 0].set_title('Velocidad del Viento', fontsize=14, fontweight='bold')\n",
    "    axes[1, 0].set_ylabel('m/s')\n",
    "    axes[1, 0].tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # Distribución de condiciones meteorológicas\n",
    "    weather_counts = df_weather_current['weather_main'].value_counts()\n",
    "    weather_counts.plot(kind='pie', ax=axes[1, 1], autopct='%1.1f%%')\n",
    "    axes[1, 1].set_title('Distribución de Condiciones', fontsize=14, fontweight='bold')\n",
    "    axes[1, 1].set_ylabel('')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "else:\n",
    "    print(\"⚠️ No hay datos para visualizar\")"
