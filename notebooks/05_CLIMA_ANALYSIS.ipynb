  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar variables de entorno\n",
    "PROJECT_ROOT = Path.cwd().parent if 'notebooks' in str(Path.cwd()) else Path.cwd()\n",
    "load_dotenv(PROJECT_ROOT / '.env')\n",
    "\n",
    "# API Keys - Intentar múltiples opciones\n",
    "OPENWEATHER_API_KEY = os.getenv('OPENWEATHER_API_KEY') or os.getenv('WEATHER_API_KEY')\n",
    "\n",
    "print(\"🔑 CONFIGURACIÓN DE API:\\n\")\n",
    "\n",
    "if OPENWEATHER_API_KEY:\n",
    "    print(f\"✅ OpenWeatherMap API Key: {OPENWEATHER_API_KEY[:10]}...\")\n",
    "else:\n",
    "    print(\"❌ OpenWeatherMap API Key NO configurada\")\n",
    "    print(\"\\n📝 CÓMO OBTENER UNA API KEY GRATIS:\\n\")\n",
    "    print(\"1. Ve a: https://openweathermap.org/\")\n",
    "    print(\"2. Crea una cuenta gratuita\")\n",
    "    print(\"3. Ve a 'API Keys' en tu perfil\")\n",
    "    print(\"4. Copia la API key\")\n",
    "    print(\"5. Agrégala a tu archivo .env:\")\n",
    "    print(\"   OPENWEATHER_API_KEY=tu_api_key_aqui\")\n",
    "    print(\"\\n⚠️ IMPORTANTE: Espera ~10 minutos después de crear la cuenta\")\n",
    "    print(\"   para que la API key se active\")"
   ]
  },
