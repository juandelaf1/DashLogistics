   "source": [
    "## 🧪 PARTE 3: Probar Conexión con API"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def test_weather_api(api_key, city=\"Madrid\"):\n",
    "    \"\"\"\n",
    "    Prueba si la API key funciona correctamente.\n",
    "    \n",
    "    Args:\n",
    "        api_key: Tu API key de OpenWeatherMap\n",
    "        city: Ciudad para probar (default: Madrid)\n",
    "    \n",
    "    Returns:\n",
    "        dict con los datos del clima o None si hay error\n",
    "    \"\"\"\n",
    "    if not api_key:\n",
    "        print(\"❌ No se proporcionó API key\")\n",
    "        return None\n",
    "    \n",
    "    # API endpoint para clima actual\n",
    "    base_url = \"http://api.openweathermap.org/data/2.5/weather\"\n",
    "    \n",
    "    params = {\n",
    "        'q': city,\n",
    "        'appid': api_key,\n",
    "        'units': 'metric',  # Para celsius\n",
    "        'lang': 'es'        # Descripciones en español\n",
    "    }\n",
    "    \n",
    "    try:\n",
    "        print(f\"🔄 Probando conexión para {city}...\")\n",
    "        response = requests.get(base_url, params=params, timeout=10)\n",
    "        \n",
    "        if response.status_code == 200:\n",
    "            data = response.json()\n",
    "            print(\"\\n✅ CONEXIÓN EXITOSA\")\n",
    "            print(f\"\\n📍 Ciudad: {data['name']}, {data['sys']['country']}\")\n",
    "            print(f\"🌡️ Temperatura: {data['main']['temp']}°C\")\n",
    "            print(f\"🌡️ Sensación térmica: {data['main']['feels_like']}°C\")\n",
    "            print(f\"💧 Humedad: {data['main']['humidity']}%\")\n",
    "            print(f\"☁️ Descripción: {data['weather'][0]['description'].capitalize()}\")\n",
    "            print(f\"💨 Viento: {data['wind']['speed']} m/s\")\n",
    "            \n",
    "            if 'rain' in data:\n",
    "                print(f\"🌧️ Lluvia (1h): {data['rain'].get('1h', 0)} mm\")\n",
    "            \n",
    "            return data\n",
    "        \n",
    "        elif response.status_code == 401:\n",
    "            print(\"\\n❌ ERROR: API Key inválida o no activada\")\n",
    "            print(\"   Verifica que:\")\n",
    "            print(\"   1. La API key esté correcta en el .env\")\n",
    "            print(\"   2. Han pasado al menos 10 minutos desde que la creaste\")\n",
    "            return None\n",
    "        \n",
    "        else:\n",
    "            print(f\"\\n❌ ERROR {response.status_code}: {response.text}\")\n",
    "            return None\n",
    "    \n",
    "    except requests.exceptions.Timeout:\n",
    "        print(\"\\n❌ ERROR: Timeout - La API no respondió a tiempo\")\n",
    "        return None\n",
    "    \n",
    "    except Exception as e:\n",
    "        print(f\"\\n❌ ERROR inesperado: {e}\")\n",
    "        return None\n",
    "\n",
    "# Probar la API\n",
    "if OPENWEATHER_API_KEY:\n",
    "    test_data = test_weather_api(OPENWEATHER_API_KEY)\n",
    "else:\n",
    "    print(\"⚠️ No se puede probar - configura la API key primero\")"
   ]
  },
