    "if not df_weather_current.empty:\n",
    "    # Crear directorio processed si no existe\n",
    "    processed_dir = PROJECT_ROOT / 'data' / 'processed'\n",
    "    processed_dir.mkdir(parents=True, exist_ok=True)\n",
    "    \n",
    "    # Guardar CSV\n",
    "    output_path = processed_dir / 'weather_data_current.csv'\n",
    "    df_weather_current.to_csv(output_path, index=False)\n",
    "    print(f\"✅ Datos guardados en: {output_path}\")\n",
    "    \n",
    "    # También guardar una versión con timestamp para histórico\n",
    "    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\n",
    "    historical_path = processed_dir / f'weather_snapshot_{timestamp}.csv'\n",
    "    df_weather_current.to_csv(historical_path, index=False)\n",
    "    print(f\"✅ Snapshot guardado en: {historical_path}\")\n",
    "    \n",
    "    # Guardar también en JSON para flexibilidad\n",
    "    json_path = processed_dir / 'weather_data_current.json'\n",
    "    df_weather_current.to_json(json_path, orient='records', date_format='iso', indent=2)\n",
    "    print(f\"✅ JSON guardado en: {json_path}\")\n",
    "    \n",
    "    print(\"\\n📊 RESUMEN DE ARCHIVOS GENERADOS:\")\n",
    "    print(f\"   • CSV actual: {output_path.name}\")\n",
    "    print(f\"   • Snapshot histórico: {historical_path.name}\")\n",
    "    print(f\"   • JSON: {json_path.name}\")\n",
    "    print(f\"\\n💡 El dashboard puede cargar desde: data/processed/weather_data_current.csv\")\n",
    "else:\n",
    "    print(\"⚠️ No hay datos para guardar\")"
   ]
