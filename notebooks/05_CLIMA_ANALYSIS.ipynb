   "source": [
    "## 📥 PARTE 5: Descargar Datos del Clima Actual"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_current_weather_batch(locations, api_key):\n",
    "    \"\"\"\n",
    "    Obtiene el clima actual para múltiples ubicaciones.\n",
    "    \n",
    "    Args:\n",
    "        locations: Lista de diccionarios con 'name' y 'country'\n",
    "        api_key: Tu API key de OpenWeatherMap\n",
    "    \n",
    "    Returns:\n",
    "        DataFrame con los datos del clima\n",
    "    \"\"\"\n",
    "    weather_data = []\n",
    "    \n",
    "    base_url = \"http://api.openweathermap.org/data/2.5/weather\"\n",
    "    \n",
    "    print(f\"🔄 Descargando datos del clima para {len(locations)} ubicaciones...\\n\")\n",
    "    \n",
    "    for i, loc in enumerate(locations, 1):\n",
    "        params = {\n",
    "            'q': f\"{loc['name']},{loc['country']}\",\n",
    "            'appid': api_key,\n",
    "            'units': 'metric',\n",
    "            'lang': 'es'\n",
    "        }\n",
    "        \n",
    "        try:\n",
    "            response = requests.get(base_url, params=params, timeout=10)\n",
    "            \n",
    "            if response.status_code == 200:\n",
    "                data = response.json()\n",
    "                \n",
    "                # Extraer información relevante\n",
    "                weather_record = {\n",
    "                    'timestamp': datetime.now(),\n",
    "                    'location': loc['name'],\n",
    "                    'country': loc['country'],\n",
    "                    'location_type': loc.get('type', 'ciudad'),\n",
    "                    'latitude': data['coord']['lat'],\n",
    "                    'longitude': data['coord']['lon'],\n",
    "                    'temperature_celsius': data['main']['temp'],\n",
    "                    'feels_like_celsius': data['main']['feels_like'],\n",
    "                    'temp_min_celsius': data['main']['temp_min'],\n",
    "                    'temp_max_celsius': data['main']['temp_max'],\n",
    "                    'pressure_hpa': data['main']['pressure'],\n",
    "                    'humidity_percent': data['main']['humidity'],\n",
    "                    'weather_main': data['weather'][0]['main'],\n",
    "                    'weather_description': data['weather'][0]['description'],\n",
    "                    'clouds_percent': data['clouds']['all'],\n",
    "                    'wind_speed_ms': data['wind']['speed'],\n",
    "                    'wind_deg': data['wind'].get('deg', None),\n",
    "                    'visibility_m': data.get('visibility', None),\n",
    "                    'rain_1h_mm': data.get('rain', {}).get('1h', 0),\n",
    "                    'snow_1h_mm': data.get('snow', {}).get('1h', 0),\n",
    "                }\n",
    "                \n",
    "                weather_data.append(weather_record)\n",
    "                print(f\"   ✅ {i}/{len(locations)} - {loc['name']}: {data['main']['temp']}°C, {data['weather'][0]['description']}\")\n",
    "            \n",
    "            else:\n",
    "                print(f\"   ❌ {i}/{len(locations)} - {loc['name']}: Error {response.status_code}\")\n",
    "            \n",
    "            # Respetar rate limits (60 llamadas/minuto en plan gratuito)\n",
    "            time.sleep(1)\n",
    "        \n",
    "        except Exception as e:\n",
    "            print(f\"   ❌ {i}/{len(locations)} - {loc['name']}: {e}\")\n",
    "    \n",
    "    # Convertir a DataFrame\n",
    "    df_weather = pd.DataFrame(weather_data)\n",
    "    \n",
    "    print(f\"\\n✅ Descarga completada: {len(df_weather)} registros\")\n",
    "    \n",
    "    return df_weather\n",
    "\n",
    "# Ejecutar descarga\n",
    "if OPENWEATHER_API_KEY:\n",
    "    df_weather_current = get_current_weather_batch(LOCATIONS, OPENWEATHER_API_KEY)\n",
    "    \n",
    "    # Mostrar resultado\n",
    "    if not df_weather_current.empty:\n",
    "        print(\"\\n📊 DATOS DESCARGADOS:\")\n",
    "        display(df_weather_current.head())\n",
    "        print(f\"\\nShape: {df_weather_current.shape}\")\n",
    "else:\n",
    "    print(\"⚠️ Configura la API key para descargar datos\")\n",
    "    df_weather_current = pd.DataFrame()"
   ]
  },
